<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/reminderListFragment">

    <fragment
        android:id="@+id/reminderListFragment"
        android:name="br.com.easyreminder.ui.reminder.ReminderListFragment"
        android:label="Easy Reminder">

        <action
            android:id="@+id/action_list_to_create"
            app:destination="@+id/reminderCreateFragment" />

        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@+id/reminderDetailFragment" />

        <action
            android:id="@+id/action_list_to_settings"
            app:destination="@+id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/reminderCreateFragment"
        android:name="br.com.easyreminder.ui.reminder.ReminderCreateFragment"
        android:label="Novo Lembrete" />

    <fragment
        android:id="@+id/reminderDetailFragment"
        android:name="br.com.easyreminder.ui.reminder.ReminderDetailFragment"
        android:label="Detalhe">

        <argument
            android:name="reminderId"
            app:argType="integer"
            android:defaultValue="-1" />

    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="br.com.easyreminder.ui.settings.SettingsFragment"
        android:label="Configurações" />


</navigation>